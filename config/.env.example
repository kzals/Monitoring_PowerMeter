# InfluxDB v2
INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=your-influx-token
INFLUX_ORG=My_Testing
INFLUX_BUCKET=powermeter
INFLUX_MEASUREMENT=pm2220

# Polling intervals
# Machine poll = baca data dari PM2220
# API poll = kirim data terbaru ke InfluxDB
PM2220_MACHINE_POLL_INTERVAL_SEC=5
PM2220_API_POLL_INTERVAL_SEC=10

# Dummy mode: set true if you want the program to run without a physical meter
PM2220_DUMMY_MODE=false

# Optional per-device overrides using device name from config.json.
# Example for device name "pm2220-01" -> key suffix "PM2220_01"
# PM2220_SERIAL_PORT_PM2220_01=COM7
# PM2220_SLAVE_ID_PM2220_01=2
# PM2220_MACHINE_POLL_INTERVAL_SEC_PM2220_01=5
# PM2220_API_POLL_INTERVAL_SEC_PM2220_01=10
# PM2220_DUMMY_MODE_PM2220_01=true

# Device communication defaults
PM2220_SERIAL_PORT=COM3
PM2220_BAUDRATE=9600
PM2220_BYTESIZE=8
PM2220_PARITY=N
PM2220_STOPBITS=1
PM2220_TIMEOUT_SEC=1.0
PM2220_SLAVE_ID=1

# Register addressing and endian
# PM2xxx register list is commonly 1-based for documentation.
# If your reads are shifted, try 0 instead of -1.
REGISTER_ADDRESS_OFFSET=-1
REGISTER_BYTE_ORDER=BIG
REGISTER_WORD_ORDER=BIG

LOG_LEVEL=INFO
